NODE_ENV=production
PORT=3001
TRUST_PROXY=1

CORS_ORIGIN=https://panel.example.com

DB_HOST=ls-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.c123456789.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=seep_app_user
DB_PASSWORD=CHANGE_ME
DB_NAME=seep_taller
DB_POOL_LIMIT=10
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_PATH=/home/ubuntu/certs/global-bundle.pem

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=10m

REFRESH_COOKIE_NAME=seep_rt
REFRESH_DAYS_REMEMBER=30
REFRESH_DAYS_SESSION=1
COOKIE_SAMESITE=lax
COOKIE_SECURE=true
